# VeoMuse V3.1 Pro 环境变量配置

# --- 生产安全变量（生产环境必填） ---
JWT_SECRET="replace-with-32+chars-random-jwt-secret"
SECRET_ENCRYPTION_KEY="replace-with-32-bytes-hex-or-base64"
ADMIN_TOKEN="replace-with-admin-token"
REDIS_PASSWORD="replace-with-strong-password"

# --- 核心 AI 密钥 ---
# 支持多个密钥以逗号分隔，实现自动轮询
GEMINI_API_KEYS="your_key_1,your_key_2"

# --- 服务配置 ---
PORT=33117
NODE_ENV=development

# 前端访问后端 API 基地址
VITE_API_BASE_URL="http://localhost:33117"

# 可选：SLO 门禁脚本默认拉取地址
SLO_GATE_API_BASE="http://127.0.0.1:33117"
# 可选：管理员 SLO 样本预热接口开关（默认关闭，建议仅 CI 临时开启）
SLO_ADMIN_SEED_ENABLED="false"

# --- 存储配置 ---
# 视频生成产物的物理存储路径
UPLOADS_PATH="./uploads"
# 上传 provider（当前仅支持 local）
STORAGE_PROVIDER="local"
LOCAL_STORAGE_ROOT="./uploads/workspace"

# --- 后端数据库 (未来扩展) ---
# DATABASE_URL="postgresql://user:password@localhost:45432/veomuse"
# REDIS_URL="redis://localhost:46379"

# --- 兼容性特性变量（当前实现默认开启，暂未动态开关化） ---
FEATURE_MODEL_POLICY_V2="true"
FEATURE_CREATIVE_LOOP_V2="true"
FEATURE_COLLAB_WS="true"
