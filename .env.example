# VeoMuse V3.1 Pro 环境变量配置

# --- 核心 AI 密钥 ---
# 支持多个密钥以逗号分隔，实现自动轮询
GEMINI_API_KEYS="your_key_1,your_key_2"

# --- 服务配置 ---
PORT=3001
NODE_ENV=development

# --- 存储配置 ---
# 视频生成产物的物理存储路径
UPLOADS_PATH="./uploads"

# --- 后端数据库 (未来扩展) ---
# DATABASE_URL="postgresql://user:password@localhost:5432/veomuse"
# REDIS_URL="redis://localhost:6379"
