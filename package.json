{
  "name": "@veomuse/root",
  "version": "3.2.0",
  "private": true,
  "description": "VeoMuse V3.2 Pro - Flagship AI Video Bus (Bun Monorepo Root)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"bun run --cwd apps/backend dev\" \"bun run --cwd apps/frontend dev\"",
    "build": "bun run --cwd packages/shared build && bun run --cwd apps/backend build && bun run --cwd apps/frontend build",
    "test": "NODE_ENV=test bun test tests/*.test.ts tests/*.test.tsx --max-concurrency 1",
    "test:dom": "NODE_ENV=test bun test tests/*.dom.test.tsx --max-concurrency 1",
    "test:coverage:raw": "bun test tests/*.test.ts tests/*.test.tsx --coverage --coverage-reporter=text --coverage-reporter=lcov --max-concurrency 1",
    "test:coverage": "bun run scripts/coverage_gate.ts",
    "e2e": "env -u NO_COLOR playwright test",
    "e2e:smoke": "env -u NO_COLOR playwright test --project=smoke-chromium",
    "e2e:regression": "env -u NO_COLOR playwright test --project=regression-chromium",
    "e2e:install": "playwright install chromium",
    "e2e:regression:mock": "env -u NO_COLOR playwright test --project=regression-chromium --grep @mock",
    "e2e:regression:real": "env -u NO_COLOR playwright test --project=regression-chromium --grep @real",
    "security:scan": "bun run scripts/secrets_guard.ts",
    "security:scan:staged": "bun run scripts/secrets_guard.ts --staged",
    "quality:api-contract:generate": "bun run scripts/generate_api_route_registry.ts",
    "quality:api-contract": "bun run quality:api-contract:generate && bun run scripts/api_contract_guard.ts",
    "quality:coverage-targets": "bun run scripts/target_coverage_guard.ts",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "stress:collab-ws": "bun run scripts/collab_ws_stress.ts",
    "drill:db-repair": "bun run scripts/db_repair_drill.ts",
    "deploy:oneclick": "bash scripts/one-click-deploy.sh",
    "deploy:oneclick:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/one-click-deploy.ps1",
    "release:gate": "bun run scripts/release_gate.ts",
    "release:gate:delivery": "bun run release:gate && bun run docker:smoke",
    "release:real:precheck": "E2E_REAL_CHANNELS=true bun run scripts/real_e2e_precheck.ts",
    "release:gate:real": "E2E_REAL_CHANNELS=true bun run scripts/release_gate.ts --with-real-e2e",
    "lint": "bun run --cwd packages/shared lint && bun run --cwd apps/backend lint && bun run --cwd apps/frontend lint && bun run --cwd apps/frontend lint:eslint",
    "format": "prettier . --write --ignore-unknown",
    "format:prettier": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "quality:full": "bun run format:check && bun run lint && bun run build && bun run test:coverage && bun run quality:coverage-targets && bun run quality:api-contract && bun run e2e:smoke -- --workers=1 --retries=0 && bun run release:gate",
    "docker:smoke": "bun run scripts/docker_smoke_check.ts",
    "docker:ui-smoke": "env -u NO_COLOR PLAYWRIGHT_BASE_URL=http://127.0.0.1:18081 PLAYWRIGHT_API_BASE_URL=http://127.0.0.1:18081 bunx playwright test -c playwright.docker.config.ts --project=docker-smoke-chromium --workers=1",
    "docker:drill:persistence": "bun run scripts/docker_persistence_drill.ts",
    "docker:up": "docker compose -f config/docker/docker-compose.yml up -d --build --wait --wait-timeout 180",
    "docker:down": "docker compose -f config/docker/docker-compose.yml down",
    "clean": "bun run scripts/clean_workspace.ts"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "20.8.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/bun": "1.3.9",
    "concurrently": "^8.2.2",
    "prettier": "^3.6.2"
  },
  "overrides": {
    "browserslist": "4.28.1",
    "baseline-browser-mapping": "2.10.0"
  }
}
