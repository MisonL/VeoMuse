{
  "name": "@veomuse/root",
  "version": "3.1.0",
  "private": true,
  "description": "VeoMuse V3.1 Pro - Flagship AI Video Bus (Bun Monorepo Root)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"bun run --cwd apps/backend dev\" \"bun run --cwd apps/frontend dev\"",
    "build": "bun run --cwd packages/shared build && bun run --cwd apps/backend build && bun run --cwd apps/frontend build",
    "test": "bun test tests/*.test.ts",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --project=smoke-chromium",
    "e2e:regression": "playwright test --project=regression-chromium",
    "e2e:install": "playwright install chromium",
    "e2e:regression:mock": "playwright test --project=regression-chromium --grep @mock",
    "e2e:regression:real": "playwright test --project=regression-chromium --grep @real",
    "security:scan": "bun run scripts/secrets_guard.ts",
    "security:scan:staged": "bun run scripts/secrets_guard.ts --staged",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "stress:collab-ws": "bun run scripts/collab_ws_stress.ts",
    "drill:db-repair": "bun run scripts/db_repair_drill.ts",
    "deploy:oneclick": "bash scripts/one-click-deploy.sh",
    "deploy:oneclick:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/one-click-deploy.ps1",
    "release:gate": "bun run scripts/release_gate.ts",
    "release:gate:real": "bun run scripts/release_gate.ts --with-real-e2e",
    "lint": "bun run --cwd packages/shared lint && bun run --cwd apps/backend lint",
    "docker:up": "docker-compose -f config/docker/docker-compose.yml up -d --build",
    "docker:down": "docker-compose -f config/docker/docker-compose.yml down",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "concurrently": "^8.2.2"
  }
}
